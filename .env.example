# Proteome Profiler run sheet.
#
# Copy this file to `.env`, then edit `.env`.
# Do not commit `.env`; it contains machine-local paths and analysis settings.
#
# List convention:
# - Use `|` between list items.
# - Use `;` between comparison entries.
# - Use `control=treatment1|treatment2` for comparisons.
# - Keep sample rows in the manifest CSV, not in this file.

PROTEOME_PROFILER_ANALYSIS=demo_replicate
PROTEOME_PROFILER_MODE=replicate
PROTEOME_PROFILER_USER=demo
PROTEOME_PROFILER_SLUG=demo_replicate

PROTEOME_PROFILER_RUNTIME_ROOT=demo/runtime
PROTEOME_PROFILER_CLOUD_PARENT=

PROTEOME_PROFILER_PROTOCOL_PRESET=cytokine_xl
PROTEOME_PROFILER_PROTOCOL_WORKBOOK=demo/protocols/demo_protocol.xlsx
PROTEOME_PROFILER_PROTOCOL_PDF=demo/protocols/demo_protocol.pdf
PROTEOME_PROFILER_PROTOCOL_PAGES="17|18|19"

PROTEOME_PROFILER_INPUT_MANIFEST=demo/manifests/demo_replicate_samples.csv
PROTEOME_PROFILER_TREATMENT_COLUMN=treatment
PROTEOME_PROFILER_SUBGROUP_COLUMN=sex

PROTEOME_PROFILER_COMPARISONS="control=treated"
PROTEOME_PROFILER_REF_COORDS="A3,4"
PROTEOME_PROFILER_REF_SIGNAL=70

PROTEOME_PROFILER_MIN_REPS_PER_ARM=2
PROTEOME_PROFILER_P_ADJUST_METHOD=BH
PROTEOME_PROFILER_ALPHA=0.05
PROTEOME_PROFILER_ANALYSIS_METHODS="raw_log2_lm|normalized_t_test"

# Optional: selected-analyte follow-up plots.
# Leave these blank to run setup validation, threshold diagnostics, and main analysis only.
# The demo fills them in so `scripts/select-analytes-analysis.R` can be run after `scripts/main.R`.
# Replicate-aware shortlist comparison slugs use:
#   <subgroup value>_<control label>_vs_<treatment label>
# Example: subgroup `male`, comparison `control=treated` -> `male_control_vs_treated`.
# Use `|` between multiple selected comparison slugs.
PROTEOME_PROFILER_SHORTLIST_COMPARISONS="male_control_vs_treated|female_control_vs_treated"
PROTEOME_PROFILER_SHORTLIST_METHODS="raw_log2_lm|normalized_t_test"
PROTEOME_PROFILER_SHORTLIST_COORDS="A1,2|A3,4"
